# MCP Server Configuration
MCP_SERVER_NAME=wakalat-ai-legal-assistant
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_PORT=8000

# AI Model Configuration
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic Configuration (Alternative)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Vector Database Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=legal_cases

# Supabase Configuration (for vector embeddings)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Database Configuration
DATABASE_URL=sqlite:///./data/wakalat.db
# For PostgreSQL: postgresql://user:password@localhost/wakalat_db

# Indian Legal Resources
INDIANKANOON_BASE_URL=https://indiankanoon.org
SUPREME_COURT_API_URL=https://api.sci.gov.in
HIGH_COURT_API_URL=https://example-highcourt-api.gov.in

# Firecrawl API (for web scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Document Storage
DOCUMENT_STORAGE_PATH=./data/documents
MAX_DOCUMENT_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/wakalat-ai.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
MAX_CONCURRENT_REQUESTS=10

# Cache Configuration
CACHE_TTL_SECONDS=3600
ENABLE_CACHE=true

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
ENABLE_PRECEDENT_SEARCH=true
ENABLE_CASE_LAW_SEARCH=true
ENABLE_DOCUMENT_GENERATION=true
ENABLE_LEGAL_RESEARCH=true


